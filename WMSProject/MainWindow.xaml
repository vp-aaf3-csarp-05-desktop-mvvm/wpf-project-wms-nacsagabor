<Window x:Class="WMSProject.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:WMSProject"
        Title="MainWindow" Height="450" Width="800"
        Background="LightGray">

    <Window.DataContext>
        <local:EmployeeViewModel />
    </Window.DataContext>

    <Grid>
        <Border HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="White"
                BorderBrush="DarkGray"
                BorderThickness="2"
                CornerRadius="8"
                Padding="50"
                MaxWidth="500">

            <StackPanel Orientation="Vertical" HorizontalAlignment="Center" Width="360">

                <Label>Heti futár kereset:</Label>
                <TextBox Text="{Binding HetiFutarFizetesInput, UpdateSourceTrigger=PropertyChanged}"
                         Width="200"/>

                <Label Margin="0,10,0,0">Ösztöndíj havonta:</Label>
                <TextBox Text="{Binding OsztondijInput, UpdateSourceTrigger=PropertyChanged}"
                         Width="200"/>

                <Button Content="Számítás"
                        Command="{Binding CalculateCommand}"
                        Width="120"
                        Margin="0,16,0,0"
                        HorizontalAlignment="Center"/>

                <Label FontSize="20"
                       FontStyle="Italic"
                       HorizontalAlignment="Center"
                       Margin="0,18,0,0">
                    Éves fizetés:
                </Label>

                <TextBlock Text="{Binding EvesFizetes}"
                           FontWeight="Bold"
                           FontSize="24"
                           HorizontalAlignment="Center"/>

            </StackPanel>
        </Border>
    </Grid>
</Window>