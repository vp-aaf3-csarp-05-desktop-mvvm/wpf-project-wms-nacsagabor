<Window x:Class="WMSProject.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WMSProject"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800"
        Background="LightGray">
    <Window.DataContext>
        <local:EmployeeViewModel />
    </Window.DataContext>

    <Grid>
        <Border HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="White"
                BorderBrush="DarkGray"
                BorderThickness="2"
                CornerRadius="8"
                Padding="50"
                MaxWidth="500">
            <StackPanel Orientation="Vertical" HorizontalAlignment="Center" Width="360">
                <Label HorizontalAlignment="Left">Heti futár kereset:</Label>
                <TextBox Text="{Binding HetiFutarFizetesInput, UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Left" Width="200"/>

                <Label HorizontalAlignment="Left" Margin="0,10,0,0">Ösztöndíj havonta:</Label>
                <TextBox Text="{Binding OsztondijInput, UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Left" Width="200"/>

                <Button Content="Számítás" Command="{Binding CalculateCommand}" Width="120" Margin="0,16,0,0" HorizontalAlignment="Center"/>

                <Label FontSize="20" FontStyle="Italic" HorizontalAlignment="Center" Margin="0,18,0,0">Éves fizetés:</Label>
                <TextBlock FontWeight="Bold" Text="{Binding EvesFizetes}" FontSize="24" HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
