<Window x:Class="WMSProject.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WMSProject"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800"
        Background="LightGray">
    <Window.DataContext>
        <local:EmployeeViewModel />
    </Window.DataContext>

    <Grid>
        <Border HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="White"
                BorderBrush="DarkGray"
                BorderThickness="2"
                CornerRadius="8"
                Padding="50"
                MaxWidth="500">
            <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                <Label HorizontalAlignment="Left">Heti futár kereset:</Label>
                <TextBlock Text="{Binding HetiFutarFizetes}" HorizontalAlignment="Left"/>
                <Label HorizontalAlignment="Right">Ösztöndíj havonta:</Label>
                <TextBlock Text="{Binding Osztondij}"/>
                <Label FontSize="20" FontStyle="Italic" HorizontalAlignment="Center">Éves fizetés:</Label>
                <TextBlock FontWeight="Bold" Text="{Binding EvesFizetes}" FontSize="24" HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
